generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["Santai", "auth"]
}

/// ── auth schema — Better Auth managed tables ──────────
model User {
  id               String    @id
  name             String
  email            String    @unique
  emailVerified    Boolean   @default(false)
  image            String?
  username         String?   @unique
  displayUsername  String?
  studyProgram     String    @default("TI")
  semester         Int       @default(1)
  role             String    @default("User")
  plan             String    @default("free")
  avatar           String    @default("")
  coverImage       String    @default("")
  bio              String    @default("")
  website          String    @default("")
  location         String    @default("")
  reputationPoints Int       @default(0)
  level            String    @default("Beginner")
  readme           String    @default("")
  readmeType       String    @default("text")
  pinnedProjects   String    @default("[]")
  twoFactorEnabled Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  ownedProjects   Project[]
  teamMembers     TeamMember[]
  contributions   Contribution[]
  ideas           Idea[]
  castVotes       Vote[]
  comments        Comment[]
  sessions        Session[]
  accounts        Account[]

  @@schema("auth")
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("auth")
  @@map("session")
}

model Account {
  id                   String    @id
  accountId            String
  providerId           String
  userId               String
  accessToken          String?
  refreshToken         String?
  idToken              String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  password             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("auth")
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@schema("auth")
  @@map("verification")
}

/// ── Santai schema (all business tables) ─────────────
model Project {
  id               String   @id @default(cuid())
  title            String
  description      String
  problemStatement String   @default("")
  status           String   @default("Open")
  techStack        String   @default("")
  demoLink         String   @default("")
  resultSummary    String   @default("")
  impactSummary    String   @default("")
  creatorId        String
  createdAt        DateTime @default(now())

  creator       User           @relation(fields: [creatorId], references: [id])
  teamMembers   TeamMember[]
  projectRoles  ProjectRole[]
  contributions Contribution[]
  comments      Comment[]

  @@schema("Santai")
}

model ProjectRole {
  id           String @id @default(cuid())
  projectId    String
  studyProgram String
  required     Int    @default(1)
  filled       Int    @default(0)

  project Project @relation(fields: [projectId], references: [id])

  @@schema("Santai")
}

model TeamMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])

  @@schema("Santai")
}

model Idea {
  id           String   @id @default(cuid())
  title        String
  description  String
  studyProgram String   @default("")
  userId       String
  voteCount    Int      @default(0)
  createdAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  comments  Comment[]
  castVotes Vote[]

  @@schema("Santai")
}

model Vote {
  id     String @id @default(cuid())
  ideaId String
  userId String

  idea  Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user  User @relation(fields: [userId], references: [id])

  @@unique([ideaId, userId])

  @@schema("Santai")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  ideaId    String?
  projectId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  idea    Idea?    @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("Santai")
}

model Contribution {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  points      Int
  type        String
  description String
  createdAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@schema("Santai")
}

model Source {
  id        String         @id @default(cuid())
  name      String         @unique
  type      String
  url       String         @default("")
  rssUrl    String         @default("")
  status    String         @default("active")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  articles  Article[]
  youtube   YouTubeVideo[]

  @@schema("Santai")
}

model Article {
  id          String   @id @default(cuid())
  sourceId    String
  title       String
  description String   @default("")
  url         String   @unique
  image       String   @default("")
  category    String   @default("")
  sentiment   String   @default("neutral")
  content     String   @default("")
  language    String   @default("id")
  country     String   @default("id")
  publishedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  source Source @relation(fields: [sourceId], references: [id])

  @@schema("Santai")
}

model YouTubeVideo {
  id          String   @id @default(cuid())
  videoId     String   @unique
  sourceId    String
  title       String
  description String   @default("")
  channelName String   @default("")
  thumbnail   String   @default("")
  views       Int      @default(0)
  category    String   @default("")
  language    String   @default("id")
  country     String   @default("id")
  publishedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  source Source @relation(fields: [sourceId], references: [id])

  @@schema("Santai")
}

model Keyword {
  id        String   @id @default(cuid())
  keyword   String   @unique
  category  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("Santai")
}

/// ── Linear webhook events ───────────────────────────
model LinearWebhookEvent {
  id        String   @id @default(cuid())
  action    String   @default("")
  type      String   @default("")
  payload   String   @default("{}")
  issueId   String?
  createdAt DateTime @default(now())

  @@schema("Santai")
  @@map("linear_webhook_event")
}

/// ── Better Auth: two-factor authentication ──────────
model TwoFactor {
  id          String  @id
  userId      String
  secret      String
  backupCodes String?
  verified    Boolean @default(false)

  @@schema("auth")
  @@map("twoFactor")
}
